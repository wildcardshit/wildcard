# Copy this file to `.dev.vars` (untracked by git) for local development
# with `wrangler pages dev`. Never commit the real `.dev.vars` file or a
# real secret key to source control.

STRIPE_SECRET_KEY=sk_test_your_test_key_here

# Signing secret for the /api/stripe-webhook endpoint. For local testing,
# run `stripe listen --forward-to localhost:8788/api/stripe-webhook` (Stripe
# CLI) and use the "whsec_..." secret it prints. In production, use the
# signing secret shown for the endpoint in the Stripe Dashboard.
STRIPE_WEBHOOK_SIGNING_SECRET=whsec_your_webhook_signing_secret_here

# Admin dashboard (/admin/) credentials — see functions/README.md's "Admin
# dashboard" section and run `node scripts/hash-admin-password.mjs` to
# generate ADMIN_PASSWORD_HASH and a random ADMIN_SESSION_SECRET. Never put
# a real plaintext password in ADMIN_PASSWORD_HASH; it must be the hashed
# output of that script.
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=pbkdf2-sha256$210000$your_salt_hex$your_hash_hex
ADMIN_SESSION_SECRET=a_long_random_string_at_least_32_bytes

# Cloudflare Pages custom headers.
# https://developers.cloudflare.com/pages/configuration/headers/
#
# Applies defense-in-depth headers to the admin dashboard and its API on
# top of the auth enforced in functions/admin/_middleware.js and
# functions/api/admin/_middleware.js: never cache admin responses, never
# frame them, don't index them, and restrict what they're allowed to load.

/admin/*
  Cache-Control: no-store
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  X-Robots-Tag: noindex, nofollow, noarchive
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'none'; form-action 'self'

/admin-login.html
  Cache-Control: no-store
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  X-Robots-Tag: noindex, nofollow, noarchive
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'none'; form-action 'self'

/api/admin/*
  Cache-Control: no-store
  X-Content-Type-Options: nosniff
